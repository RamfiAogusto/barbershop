# Google Analytics 4 - Measurement ID (formato G-XXXXXXXXXX)
# Conseguilo en https://analytics.google.com -> Admin -> Data Streams -> tu stream web
NEXT_PUBLIC_GA_ID=

# Google Search Console - verification code
# Conseguilo en https://search.google.com/search-console -> Configuracion -> Verificacion de la propiedad -> Etiqueta HTML
# Pega SOLO el valor del meta tag (no toda la etiqueta)
NEXT_PUBLIC_GSC_VERIFICATION=
